rules_version = '2';

// ============================================================
// PASTE THIS INTO: Firebase Console > Firestore Database > Rules
// ============================================================
//
// Model:
//  - allowedUsers/{uid}  is the access-control gate AND the account-
//    type record. A signed-in Firebase Auth account grants NOTHING
//    by itself — the app only lets someone in if their UID has a doc
//    here, and the doc's `role` field ("couple" | "coordinator" |
//    "admin") decides which page they land on. Only existing admins
//    can create/update/delete these docs, which is how "add a login"
//    / "revoke access" is enforced server-side (not just hidden in
//    the UI).
//
// Note: couple.html and coordinator.html store the actual wedding
// planning data (checklist, budget, guests, seating, etc.) in the
// browser's localStorage, not in Firestore — so there's no per-user
// data collection to protect here. Firestore's only job in this app
// is the login gate above.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid));
    }

    function isAdmin() {
      return request.auth != null &&
        isAllowed() &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)).data.role == 'admin';
    }

    match /allowedUsers/{userId} {
      // Anyone signed in can read their OWN doc (to check their own access + role).
      allow get: if request.auth != null && request.auth.uid == userId;
      // Only admins can list everyone (for the admin panel table).
      allow list: if isAdmin();
      // Only admins can grant or revoke access.
      allow create, update, delete: if isAdmin();
    }
  }
}

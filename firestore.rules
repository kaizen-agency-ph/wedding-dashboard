rules_version = '2';

// ============================================================
// PASTE THIS INTO: Firebase Console > Firestore Database > Rules
// ============================================================
//
// Model:
//  - allowedUsers/{uid}  is the access-control gate. A signed-in
//    Firebase Auth account grants NOTHING by itself — the app only
//    lets someone into the dashboard if their UID has a doc here.
//    Only existing admins can create/update/delete these docs, which
//    is how "add a login" / "revoke access" is enforced server-side
//    (not just hidden in the UI).
//  - weddings/{uid}      holds each user's checklist/budget/guest
//    data. Only that user (and only if still an allowed user) can
//    read or write it.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid));
    }

    function isAdmin() {
      return request.auth != null &&
        isAllowed() &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)).data.role == 'admin';
    }

    match /allowedUsers/{userId} {
      // Anyone signed in can read their OWN doc (to check their own access).
      allow get: if request.auth != null && request.auth.uid == userId;
      // Only admins can list everyone (for the admin panel table).
      allow list: if isAdmin();
      // Only admins can grant or revoke access.
      allow create, update, delete: if isAdmin();
    }

    match /weddings/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId &&
        isAllowed();
    }
  }
}
